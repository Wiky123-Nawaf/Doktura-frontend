<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Us - Doktura.ai</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        /* --- Reset & Base Styles --- */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            color: #1a1a1a;
            line-height: 1.5;
            -webkit-font-smoothing: antialiased;
            overflow-x: hidden;
            background-color: var(--bg-grayish); /* Light background to make the form pop */
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        a {
            text-decoration: none;
            color: inherit;
        }

        button {
            font-family: inherit;
            cursor: pointer;
        }

        /* --- Color Variables --- */
        :root {
            --primary-blue: #0066cc;
            --light-blue-bg: #eef5ff;
            --bg-white: #ffffff;
            --bg-grayish: #f8f9fc;
            --card-grayish: #f4f6fa;
            --text-dark: #111111;
            --text-gray: #666666;
            --border-gray: #e0e0e0;
            --footer-bg: #111111;
            --footer-text-muted: #a0aab5;
        }

        /* --- Layout Containers --- */
        .section-white { background-color: var(--bg-white); }
        .section-grayish { background-color: var(--bg-grayish); }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 24px;
        }

        main {
            flex-grow: 1; /* Pushes footer to bottom */
        }

        /* --- Components --- */
        .btn-primary {
            background-color: var(--primary-blue);
            color: white;
            border: none;
            border-radius: 999px;
            padding: 14px 32px;
            font-size: 15px;
            font-weight: 600;
            display: inline-flex;
            justify-content: center;
            align-items: center;
            gap: 8px;
            transition: all 0.2s;
            width: 100%;
        }
        
        .btn-primary:hover { 
            opacity: 0.9; 
            transform: translateY(-1px);
            box-shadow: 0 8px 24px rgba(0, 102, 204, 0.25);
        }

        /* --- Header --- */
        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 24px 0;
            background-color: var(--bg-white);
        }

        .logo {
            height: 32px;
            width: auto;
            object-fit: contain;
        }

        nav {
            display: flex;
            align-items: center;
            gap: 32px;
        }

        .nav-links {
            display: flex;
            gap: 24px;
            font-size: 14px;
            color: var(--text-dark);
            font-weight: 500;
        }

        .nav-links a:hover { color: var(--primary-blue); }
        
        .nav-btn {
            padding: 10px 24px;
            width: auto;
        }

        /* --- Contact Section --- */
        .contact-section {
            padding: 80px 0 100px 0;
            position: relative;
        }

        /* Subtle background glow */
        .contact-section::before {
            content: '';
            position: absolute;
            top: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 800px;
            height: 800px;
            background: radial-gradient(circle, rgba(0, 102, 204, 0.05) 0%, rgba(255, 255, 255, 0) 70%);
            z-index: 0;
            pointer-events: none;
        }

        .contact-card {
            background: #ffffff;
            border-radius: 24px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.04);
            border: 1px solid rgba(0,0,0,0.02);
            max-width: 600px;
            margin: 0 auto;
            padding: 56px;
            position: relative;
            z-index: 1;
        }

        .contact-header {
            text-align: center;
            margin-bottom: 40px;
        }

        .contact-header h1 {
            font-size: 32px;
            font-weight: 800;
            color: var(--text-dark);
            margin-bottom: 12px;
            line-height: 1.2;
        }

        .contact-header p {
            color: var(--text-gray);
            font-size: 16px;
        }

        /* --- Form Styles --- */
        .form-group {
            margin-bottom: 24px;
        }

        .form-label {
            display: block;
            font-size: 14px;
            font-weight: 600;
            color: var(--text-dark);
            margin-bottom: 8px;
        }

        .form-label span {
            color: var(--primary-blue); /* Red or Blue asterisk */
        }

        .form-control {
            width: 100%;
            background-color: var(--card-grayish);
            border: 1px solid transparent;
            border-radius: 12px;
            padding: 16px;
            font-family: inherit;
            font-size: 15px;
            color: var(--text-dark);
            outline: none;
            transition: all 0.2s ease;
        }

        .form-control::placeholder {
            color: #a0aab5;
        }

        .form-control:focus {
            background-color: #ffffff;
            border-color: var(--primary-blue);
            box-shadow: 0 0 0 4px rgba(0, 102, 204, 0.1);
        }

        textarea.form-control {
            resize: vertical;
            min-height: 140px;
        }

        /* --- Footer Section --- */
        .footer-section {
            padding: 40px 24px;
            background-color: var(--bg-grayish); 
        }

        .footer-card {
            background-color: var(--footer-bg);
            color: #ffffff;
            border-radius: 32px;
            padding: 60px;
            max-width: 1200px;
            margin: 0 auto;
        }

        .footer-top {
            display: flex;
            justify-content: space-between;
            gap: 60px;
            padding-bottom: 60px;
        }

        .footer-brand {
            max-width: 380px;
        }

        .footer-logo-wrapper {
            background: white;
            display: inline-block;
            padding: 8px 16px;
            border-radius: 12px;
            margin-bottom: 24px;
        }

        .footer-brand p {
            color: var(--footer-text-muted);
            font-size: 16px;
            line-height: 1.6;
        }

        .footer-links-group {
            display: flex;
            gap: 100px;
        }

        .footer-col h4 {
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 24px;
            color: #ffffff;
        }

        .footer-col a {
            display: block;
            color: var(--footer-text-muted);
            font-size: 15px;
            margin-bottom: 16px;
            text-decoration: none;
            transition: color 0.2s;
        }

        .footer-col a:last-child {
            margin-bottom: 0;
        }

        .footer-col a:hover {
            color: #ffffff;
        }

        .footer-bottom {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-top: 40px;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
        }

        .footer-bottom p {
            color: var(--footer-text-muted);
            font-size: 15px;
        }

        .social-area {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .social-area span {
            color: #ffffff;
            font-weight: 500;
            font-size: 15px;
        }

        .social-icons {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .social-icons a {
            color: #ffffff;
            transition: opacity 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .social-icons a:hover {
            opacity: 0.7;
        }

        /* --- Media Queries --- */
        @media (max-width: 768px) {
            header { flex-direction: column; gap: 20px; padding: 20px 0; }
            .nav-links { flex-wrap: wrap; justify-content: center; }
            
            .contact-section { padding: 40px 0 60px 0; }
            .contact-card { padding: 32px 24px; border-radius: 20px; }
            .contact-header h1 { font-size: 26px; }

            .footer-section { padding: 0 16px 32px 16px; }
            .footer-card { padding: 32px 24px; border-radius: 24px; }
            .footer-top { flex-direction: column; gap: 40px; padding-bottom: 40px; }
            .footer-links-group { flex-direction: column; gap: 32px; }
            .footer-bottom { flex-direction: column; align-items: flex-start; gap: 24px; text-align: left; padding-top: 32px; }
            .social-area { flex-direction: column; align-items: flex-start; gap: 12px; }
        }
    </style>
</head>
<body>

    <!-- Header Section -->
    <div class="section-white">
        <div class="container">
            <header>
                <a href="index.html">
                    <img src="https://huggingface.co/NAwafo/SmolLM-Keyboard-GGUF/resolve/main/Logo.jpg?download=true" alt="Doktura.ai Logo" class="logo">
                </a>
                <nav>
                    <div class="nav-links">
                        <a href="index.html">Home</a>
                        <a href="#">Company</a>
                        <a href="#">Legal</a>
                        <a href="#">Support</a>
                    </div>
                    <button class="btn-primary nav-btn">Login Now</button>
                </nav>
            </header>
        </div>
    </div>

    <!-- Main Content -->
    <main>
        <section class="contact-section container">
            <div class="contact-card">
                
                <div class="contact-header">
                    <h1>Have any questions?<br>Let's answer them</h1>
                    <p>Fill out the form below and our team will get back to you shortly.</p>
                </div>

                <!-- FormSubmit Integration -->
                <form action="https://formsubmit.co/dokturamedic@gmail.com" method="POST">
                    
                    <!-- Honeypot field to prevent spam bots -->
                    <input type="text" name="_honey" style="display:none">
                    
                    <!-- Disable captcha for seamless experience (optional, remove if you want captcha) -->
                    <input type="hidden" name="_captcha" value="false">

                    <div class="form-group">
                        <label class="form-label" for="name">Name <span>*</span></label>
                        <input type="text" id="name" name="Name" class="form-control" placeholder="John Doe" required>
                    </div>

                    <div class="form-group">
                        <label class="form-label" for="email">E-mail <span>*</span></label>
                        <input type="email" id="email" name="Email" class="form-control" placeholder="john@example.com" required>
                    </div>

                    <div class="form-group">
                        <label class="form-label" for="subject">Subject <span>*</span></label>
                        <input type="text" id="subject" name="Subject" class="form-control" placeholder="How can we help?" required>
                    </div>

                    <div class="form-group">
                        <label class="form-label" for="message">Your message <span>*</span></label>
                        <textarea id="message" name="Message" class="form-control" placeholder="Write your message here..." required></textarea>
                    </div>

                    <button type="submit" class="btn-primary">
                        Send Message
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="22" y1="2" x2="11" y2="13"></line>
                            <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
                        </svg>
                    </button>
                </form>

            </div>
        </section>
    </main>

    <!-- Footer Section -->
    <footer class="footer-section">
        <div class="footer-card">
            <div class="footer-top">
                <div class="footer-brand">
                    <div class="footer-logo-wrapper">
                        <img src="https://huggingface.co/NAwafo/SmolLM-Keyboard-GGUF/resolve/main/Logo.jpg?download=true" alt="Doktura.ai Logo" style="height: 32px; display: block;">
                    </div>
                    <p>Providing AI-powered medical insights and seamless doctor bookings 24/7.</p>
                </div>

                <div class="footer-links-group">
                    <div class="footer-col">
                        <h4>Company</h4>
                        <a href="#">About</a>
                        <a href="#">Contact Us</a>
                        <a href="#">HIPAA</a>
                    </div>
                    <div class="footer-col">
                        <h4>Legal</h4>
                        <a href="https://doktura.ai/privacy.html">Privacy Policy</a>
                        <a href="#">Terms of Service</a>
                    </div>
                </div>
            </div>
            
            <div class="footer-bottom">
                <p>Alright reserve to © Doktura 2026</p>
                
                <div class="social-area">
                    <span>Connect with us</span>
                    <div class="social-icons">
                        <a href="https://www.facebook.com/dokturaai/" target="_blank" aria-label="Facebook">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
                            </svg>
                        </a>
                        <a href="https://www.instagram.com/doktura.ai/" target="_blank" aria-label="Instagram">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                                <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
                            </svg>
                        </a>
                        <a href="https://www.tiktok.com/@doktura_ai" target="_blank" aria-label="TikTok">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"></path>
                                <path d="M15 8a4 4 0 1 0 0-8c0 2.5 2 4.5 4.5 4.5V8A4 4 0 0 1 15 8z"></path>
                            </svg>
                        </a>
                        <a href="https://www.linkedin.com/company/doktura-ai" target="_blank" aria-label="LinkedIn">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
